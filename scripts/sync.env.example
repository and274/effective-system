# Copy this file to sync.env (gitignored). Use ASCII in this file for Windows PS5.
# Used by scripts/full-sync-to-server.ps1 and full-sync-to-server.sh
#
# Optional: ZHIMEDIA_SYNC_DIRECT=1  -> scp straight into REMOTE_ROOT (needs write permission there).
# If you use ubuntu and /var/www is root-owned, leave DIRECT unset: script uses ~/zhimedia-staging + sudo.

ZHIMEDIA_SYNC_HOST=your.server.ip.or.domain
ZHIMEDIA_SYNC_USER=root
ZHIMEDIA_SYNC_REMOTE_ROOT=/var/www/zhimedia-sandbox
