# ============================================
# 智媒沙盘后端配置
# ============================================

# 【必填】Flask 密钥，生产环境必须设置强密钥（>=16位）
# 示例：openssl rand -hex 32
SECRET_KEY=

# 调试模式（生产环境必须设为 false）
DEBUG=true

# ============================================
# LLM 配置
# ============================================
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_API_KEY=
LLM_MODEL=deepseek-ai/DeepSeek-V3

# ============================================
# Orchestrator 配置（场景路由）
# ============================================
ORCHESTRATOR_ENABLED=false
ORCHESTRATOR_MODEL=deepseek-ai/DeepSeek-V3
ORCHESTRATOR_API_BASE=
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_CHAT_PATH=/chat
ORCHESTRATOR_CHAT_TYPE=business
ORCHESTRATOR_TIMEOUT_SECONDS=10
ORCHESTRATOR_CONFIDENCE_THRESHOLD=0.6

# ============================================
# 会话存储
# ============================================
# 可选：memory | redis
SESSION_STORE=memory
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_PREFIX=zhimei:session:
SESSION_TTL_SECONDS=86400

# ============================================
# 历史记录存储
# ============================================
HISTORY_STORE=memory
HISTORY_KEY=zhimei:history
HISTORY_MAX_ITEMS=200

# ============================================
# 游戏参数
# ============================================
DEFAULT_SCENE_ID=zhimei
GAME_TOTAL_TIME=46
GAME_INITIAL_CREDIBILITY=100
EXTERNAL_USER_DEFAULT=zhimei_dev_demo001

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ============================================
# 日志
# ============================================
LOG_LEVEL=INFO

# ============================================
# SSE 配置
# ============================================
SSE_RETRY_TIMEOUT=30000
